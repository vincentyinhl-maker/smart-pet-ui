# 涂鸦 IoT 服务配置 — 复制为 .env 并填入真实值
# 在涂鸦平台 iot.tuya.com → Cloud → Overview 获取 Client ID 和 Client Secret

# ── 涂鸦认证凭证 ────────────────────────────────────────
TUYA_CLIENT_ID=your_access_id_here
TUYA_CLIENT_SECRET=your_access_secret_here

# ── 数据中心 (按实际区域选择) ──────────────────────────
# 中国大陆: https://openapi.tuyacn.com
# 欧洲:     https://openapi.tuyaeu.com
# 北美:     https://openapi.tuyaus.com
TUYA_BASE_URL=https://openapi.tuyacn.com

# ── 设备 ID (在涂鸦 App 设备详情或开发者平台中获取) ───────
DEVICE_ID_LITTER_BOX=your_litter_box_device_id
DEVICE_ID_FEEDER=your_feeder_device_id
DEVICE_ID_WATER=your_water_device_id

# ── 数据库配置 ────────────────────────────────────────────
DB_PATH=./data/pet_health.db

# ── 轮询间隔 (分钟) ───────────────────────────────────────
POLL_INTERVAL_MINUTES=5

# ── 服务器 ────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_me_in_production
